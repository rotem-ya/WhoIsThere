# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.join(__dir__, 'Flutter', 'Generated.xcconfig')
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Fix: strip unsupported '-G' compiler flag from BoringSSL-GRPC (Xcode 16+ / clang)
    if target.name == 'BoringSSL-GRPC'
      target.source_build_phase.files.each do |file|
        if file.settings && file.settings['COMPILER_FLAGS']
          flags = file.settings['COMPILER_FLAGS'].split
          flags.reject! { |flag| flag == '-GCC_WARN_INHIBIT_ALL_WARNINGS' }
          file.settings['COMPILER_FLAGS'] = flags.join(' ')
        end
      end
    end

    # Keep all pods buildable as frameworks with modular headers.
    # Firebase Flutter plugins can otherwise reject Firebase.h as a non-modular header.
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
    end
  end

  # Apply the same non-modular include allowance to generated aggregate targets.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.xcconfigs.each do |_config_name, xcconfig|
      xcconfig.attributes['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      xcconfig.save_as(aggregate_target.xcconfig_path(_config_name))
    end
  end

  # Fix gRPC-Core C++ parse error under Xcode 16 / newer clang. gRPC 1.62 writes
  # `Traits::template CallSeqFactory(...)` where the member is a plain function;
  # clang 16 rejects `template` unless a template-argument list follows
  # ("A template argument list is expected after a name prefixed by the template
  # keyword", basic_seq.h). Upstream (gRPC 1.66) simply dropped `template` there.
  # Strip `template` ONLY when the member is immediately called as `name(`, so
  # valid uses like `CheckResultAndRunNext<Wrapped>(` are left untouched.
  # Idempotent + re-applied on every pod install (incl. Flutter's during archive).
  grpc_root = File.join(installer.sandbox.root, 'gRPC-Core')
  if Dir.exist?(grpc_root)
    Dir.glob(File.join(grpc_root, '**', '*.{h,hpp,cc,c,mm,m}')).each do |path|
      original = File.read(path)
      patched = original.gsub(/(::|\.)template\s+([A-Za-z_]\w*)\(/, '\1\2(')
      File.write(path, patched) if patched != original
    end
  end
end
