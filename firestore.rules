rules_version = '2';
// Deployed via .github/workflows/deploy-firestore-rules.yml (firebaserules REST API).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Admin = custom claim { admin: true } (owner account) OR an allow-listed
    // login email. Keep the email list in sync with lib/core/constants/admin_config.dart.
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email in ['rot4735@gmail.com']
      );
    }

    // ── Rooms ────────────────────────────────────────────────────────────────
    // Any authenticated user may read and create rooms.
    // Any authenticated user may update a room — covers:
    //   • host advancing phase / writing game state
    //   • joining player adding themselves to players map (not yet in players)
    //   • guardian clients writing auto-reveal / guess transactions
    // Only the host may delete their room.
    match /rooms/{roomId} {
      allow read, create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn() && request.auth.uid == resource.data.hostId;

      // All nested room sub-collections (future-safe)
      match /{document=**} {
        allow read, create, update, delete: if signedIn();
      }
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user may read any user doc
      // (needed to read host's selectedCardSkin, player names, etc.)
      allow read: if signedIn();

      // The owning user — or an admin — may write the profile doc.
      // Admin writes power the separate admin app (grant coins/skins/cards).
      allow create, update: if signedIn() &&
        (request.auth.uid == userId || isAdmin());
      allow delete: if false;

      // Economy wallet — own user or admin (read+write: coins/totalEarned/…)
      match /economy/{document} {
        allow read, write: if signedIn() &&
          (request.auth.uid == userId || isAdmin());
      }

      // Economy transaction log — own user or admin (admin writes adminAdjustment)
      match /economy_transactions/{txId} {
        allow read, write: if signedIn() &&
          (request.auth.uid == userId || isAdmin());
      }

      // Exposure history — any authenticated user may read AND write.
      // Cross-user by design: _recordExposureForAll() writes to other players'
      // docs, and _pickSmartImage() reads every real player's history (the host
      // reads co-players) to rotate images without repeats. Non-sensitive data
      // (per-image view counts). Stored at users/{userId}/exposure_history/data.
      match /exposure_history/{document} {
        allow read, write: if signedIn();
      }

      // Friends list — any authenticated user may read AND write. Cross-user by
      // design: accepting a request writes the friendship onto BOTH users'
      // lists, and removing deletes both sides. Non-sensitive (name + date).
      match /friends/{friendUid} {
        allow read, write: if signedIn();
      }

      // Friends-game history — each player records their OWN finished games
      // (read open to signed-in so a friend's history could be shown later).
      match /friendGames/{gameId} {
        allow read, write: if signedIn();
      }
    }

    // ── Friend requests ───────────────────────────────────────────────────────
    // A pending request between two users (id = "{toUid}_{fromUid}"). Any
    // signed-in user may create/read/delete — the sender creates it, the
    // recipient accepts (deletes + writes the friendship) or declines (deletes).
    match /friendRequests/{requestId} {
      allow read, create, update, delete: if signedIn();
    }

    // ── Game invites ──────────────────────────────────────────────────────────
    // A pending "join my game" invite from one friend to another
    // (id = "{toUid}_{fromUid}"). Any signed-in user may create/read/delete —
    // the host creates it, the recipient reads + deletes it when they join.
    match /gameInvites/{inviteId} {
      allow read, create, update, delete: if signedIn();
    }

    // ── Direct messages (friend-to-friend chat, outside a game) ───────────────
    // Conversation id = the two uids sorted + joined ("{a}_{b}"). Any signed-in
    // user may read/write; messages live under the conversation document.
    match /directMessages/{convoId}/{document=**} {
      allow read, write: if signedIn();
    }

    // ── Place / image catalogue ───────────────────────────────────────────────
    // Read: any signed-in player (the app loads the catalogue at game start).
    // Write: admins only — a user carrying the custom claim { admin: true },
    // granted to the owner's account and used by the admin content app.
    // See docs/admin/CONTENT_SCHEMA.md.
    match /images/{imageId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.token.admin == true;
    }

    // ── Content manifest ──────────────────────────────────────────────────────
    // Read: any signed-in player — fetched once at startup to decide which places
    // are active and to discover new remote places. Write: admins only (the
    // separate admin app toggles active/inactive and adds remote places).
    match /content_manifest/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
