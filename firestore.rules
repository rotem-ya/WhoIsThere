rules_version = '2';
// Deployed via .github/workflows/deploy-firestore-rules.yml (firebaserules REST API).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Admin = custom claim { admin: true } (owner account) OR an allow-listed
    // login email. Keep the email list in sync with lib/core/constants/admin_config.dart.
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email in ['rot4735@gmail.com']
      );
    }

    // ── Rooms ────────────────────────────────────────────────────────────────
    // Any authenticated user may read and create rooms.
    // Any authenticated user may update a room — covers:
    //   • host advancing phase / writing game state
    //   • joining player adding themselves to players map (not yet in players)
    //   • guardian clients writing auto-reveal / guess transactions
    // Only the host may delete their room.
    match /rooms/{roomId} {
      allow read, create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn() && request.auth.uid == resource.data.hostId;

      // All nested room sub-collections (future-safe)
      match /{document=**} {
        allow read, create, update, delete: if signedIn();
      }
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user may read any user doc
      // (needed to read host's selectedCardSkin, player names, etc.)
      allow read: if signedIn();

      // The owning user — or an admin — may write the profile doc.
      // Admin writes power the separate admin app (grant coins/skins/cards).
      allow create, update: if signedIn() &&
        (request.auth.uid == userId || isAdmin());
      // Users may delete their OWN profile doc — required for in-app account
      // deletion (App Store Guideline 5.1.1(v)).
      allow delete: if signedIn() && request.auth.uid == userId;

      // Economy wallet — own user or admin (read+write: coins/totalEarned/…)
      match /economy/{document} {
        allow read, write: if signedIn() &&
          (request.auth.uid == userId || isAdmin());
      }

      // Economy transaction log — own user or admin (admin writes adminAdjustment)
      match /economy_transactions/{txId} {
        allow read, write: if signedIn() &&
          (request.auth.uid == userId || isAdmin());
      }

      // Exposure history — any authenticated user may read AND write.
      // Cross-user by design: _recordExposureForAll() writes to other players'
      // docs, and _pickSmartImage() reads every real player's history (the host
      // reads co-players) to rotate images without repeats. Non-sensitive data
      // (per-image view counts). Stored at users/{userId}/exposure_history/data.
      match /exposure_history/{document} {
        allow read, write: if signedIn();
      }

      // Friends list — any authenticated user may read AND write. Cross-user by
      // design: accepting a request writes the friendship onto BOTH users'
      // lists, and removing deletes both sides. Non-sensitive (name + date).
      match /friends/{friendUid} {
        allow read, write: if signedIn();
      }

      // Friends-game history — each player records their OWN finished games
      // (read open to signed-in so a friend's history could be shown later).
      match /friendGames/{gameId} {
        allow read, write: if signedIn();
      }

      // All-games history (every mode, not just friends games) — powers the
      // admin per-player stats view (opponents, host choices, result).
      match /gameHistory/{roomId} {
        allow read, write: if signedIn();
      }

      // Trick/card usage log (stun / guessBlock5 / guessBlock10 / blackout) —
      // same admin stats view. Append-only in practice; broad signedIn()
      // write matches the rest of this trusted-client app.
      match /cardUsage/{entryId} {
        allow read, write: if signedIn();
      }
    }

    // ── Friend requests ───────────────────────────────────────────────────────
    // A pending request between two users (id = "{toUid}_{fromUid}"). Any
    // signed-in user may create/read/delete — the sender creates it, the
    // recipient accepts (deletes + writes the friendship) or declines (deletes).
    match /friendRequests/{requestId} {
      allow read, create, update, delete: if signedIn();
    }

    // ── Game invites ──────────────────────────────────────────────────────────
    // A pending "join my game" invite from one friend to another
    // (id = "{toUid}_{fromUid}"). Any signed-in user may create/read/delete —
    // the host creates it, the recipient reads + deletes it when they join.
    match /gameInvites/{inviteId} {
      allow read, create, update, delete: if signedIn();
    }

    // ── Friend groups (קבוצות קבועות) ─────────────────────────────────────────
    // A saved squad: cumulative group scoreboard + persistent chat + per-game
    // score records. Same open trust model as friends/invites — membership
    // edits, chat and cross-game score recording are all client-driven, and
    // every member may read/write (scores are self-recorded per player).
    match /groups/{groupId}/{document=**} {
      allow read, write: if signedIn();
    }

    // ── Group invites ─────────────────────────────────────────────────────────
    // A pending "join my group" invite (id = "{toUid}_{groupId}"), like a
    // WhatsApp group invite — membership is only granted on accept. Any
    // signed-in user may create/read/delete: the group owner creates it, the
    // recipient accepts (writes membership on groups/{groupId} + deletes) or
    // declines (deletes).
    match /groupInvites/{inviteId} {
      allow read, create, update, delete: if signedIn();
    }

    // ── Direct messages (friend-to-friend chat, outside a game) ───────────────
    // Conversation id = the two uids sorted + joined ("{a}_{b}"). Any signed-in
    // user may read/write; messages live under the conversation document.
    match /directMessages/{convoId}/{document=**} {
      allow read, write: if signedIn();
    }

    // ── Place / image catalogue ───────────────────────────────────────────────
    // Read: any signed-in player (the app loads the catalogue at game start).
    // Write: admins only — a user carrying the custom claim { admin: true },
    // granted to the owner's account and used by the admin content app.
    // See docs/admin/CONTENT_SCHEMA.md.
    match /images/{imageId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.token.admin == true;
    }

    // ── Content manifest ──────────────────────────────────────────────────────
    // Read: any signed-in player — fetched once at startup to decide which places
    // are active and to discover new remote places. Write: admins only (the
    // separate admin app toggles active/inactive and adds remote places).
    // Public read: the game subscribes at startup BEFORE auth restores, and an
    // errored listener never recovers for the session (found via QA log
    // MANIFEST_LIVE_ERROR permission-denied). The content is public anyway —
    // the same images/names are served openly from Hosting.
    match /content_manifest/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Live store-cosmetics catalog (frames / name styles / win effects / board
    // skins) — same pattern and same pre-auth-read reasoning as the manifest.
    match /cosmetics_catalog/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Card skins (tile-back designs) ────────────────────────────────────────
    // Read: any signed-in player — the game streams active card skins
    // (firestoreSkinsProvider) for the tile-back catalog. Write: admins only
    // (the admin app publishes/edits skins live). Without this rule the
    // catch-all below blocks both, breaking live skin management.
    match /card_skins/{skinId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── App config (in-app update notice) ─────────────────────────────────────
    // Read: any signed-in player — fetched on the home screen to decide whether
    // to show the "new version available" notice. Write: admins only (the owner
    // edits app_config/app to push a notice without shipping new code).
    match /app_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── Feedback + crash reports ──────────────────────────────────────────────
    // Any signed-in user may CREATE a feedback / crash-report doc (the app sends
    // them). Only admins may read them back (they're reviewed in the admin app).
    // No updates/deletes from clients.
    // Admin may update (mark handled from the admin Inbox) and delete (cleanup).
    match /feedback/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }
    match /crash_reports/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if isAdmin();
    }

    // ── Weekly global leaderboard ────────────────────────────────────────────
    // Each ISO week is its own board (leaderboards/weekly_{weekKey}). Any signed
    // in user may READ the standings; a user may only write their OWN entry and
    // their OWN prize-claim marker. Non-sensitive (display name + points).
    match /leaderboards/{board} {
      allow read: if signedIn();
      match /entries/{uid} {
        allow read: if signedIn();
        allow create, update: if signedIn() && request.auth.uid == uid;
      }
      match /claims/{uid} {
        allow read: if signedIn();
        allow create, update: if signedIn() && request.auth.uid == uid;
      }
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
