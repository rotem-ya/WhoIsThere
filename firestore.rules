rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the user can write their own doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Economy wallet sub-document (users/{userId}/economy/wallet)
      match /economy/{document} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Economy transaction log (users/{userId}/economy_transactions/{txId})
      match /economy_transactions/{txId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Rooms: authenticated users can read; write is restricted
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      // Create: must be auth'd, hostId must match uid, phase must be waiting
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.phase == 'waiting';
      // Update: any authenticated player in the room can update
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.players.keys()
            || request.auth.uid == resource.data.hostId);
      // Delete: only the host can delete
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.hostId;
    }

    // Images: anyone authenticated can read; only admin can write
    match /images/{imageId} {
      allow read: if request.auth != null;
      allow write: if false; // managed via Firebase Console / Admin SDK
    }
  }
}
