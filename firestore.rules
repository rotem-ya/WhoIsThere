rules_version = '2';
// Deployed via .github/workflows/deploy-firestore-rules.yml (firebaserules REST API).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // ── Rooms ────────────────────────────────────────────────────────────────
    // Any authenticated user may read and create rooms.
    // Any authenticated user may update a room — covers:
    //   • host advancing phase / writing game state
    //   • joining player adding themselves to players map (not yet in players)
    //   • guardian clients writing auto-reveal / guess transactions
    // Only the host may delete their room.
    match /rooms/{roomId} {
      allow read, create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn() && request.auth.uid == resource.data.hostId;

      // All nested room sub-collections (future-safe)
      match /{document=**} {
        allow read, create, update, delete: if signedIn();
      }
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user may read any user doc
      // (needed to read host's selectedCardSkin, player names, etc.)
      allow read: if signedIn();

      // Only the owning user may write their own profile doc
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;

      // Economy wallet — own user only
      match /economy/{document} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // Economy transaction log — own user only
      match /economy_transactions/{txId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // Exposure history — any authenticated user may write.
      // _recordExposureForAll() writes to other players' docs cross-user.
      // Stored at users/{userId}/exposure_history/data (4-segment doc path).
      match /exposure_history/{document} {
        allow read: if signedIn() && request.auth.uid == userId;
        allow write: if signedIn();
      }
    }

    // ── Place / image catalogue ───────────────────────────────────────────────
    match /images/{imageId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
